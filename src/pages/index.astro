---
import PresentationShell from '../components/presentation/PresentationShell.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { presentationMeta } from '../data/presentation';
---

<BaseLayout
  title={presentationMeta.title}
  description={presentationMeta.description}
  mode="presentation"
>
  <PresentationShell />
</BaseLayout>

<script>
  import { initPresentation } from '../presentation/init';

  initPresentation();
</script>
