---
const base = import.meta.env.BASE_URL;
---

<div class="about-avatar-wrap fade-up" id="aboutAvatarCard">
  <div class="about-avatar-flip" aria-hidden="true">
    <picture>
      <source srcset={`${base}/assets/images/avatar.webp`} type="image/webp" />
      <img
        src={`${base}/assets/images/avatar.png`}
        alt="Avatar pixel art de Daniel Eduardo Bautista Fuentes"
        class="about-avatar about-avatar-front"
        width="200"
        height="200"
      />
    </picture>
    <picture>
      <source srcset={`${base}/assets/images/IMG_20240627_102303.webp`} type="image/webp" />
      <img
        src={`${base}/assets/images/IMG_20240627_102303.jpg`}
        alt="Foto de Daniel Eduardo Bautista Fuentes"
        class="about-avatar about-avatar-back"
        width="200"
        height="200"
      />
    </picture>
  </div>
  <div class="status-badge">
    <span class="status-dot"></span>
    DISPONIBLE FREELANCE
  </div>
</div>
