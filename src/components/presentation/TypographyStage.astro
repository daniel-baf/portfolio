---
import { presentationMeta } from '../../data/presentation';

const contactMailto =
  'mailto:danibaufu@gmail.com?subject=Contacto%20desde%20el%20portfolio&body=Hola%20Daniel%2C%0A%0A';
---

<div class="typography-stage" id="typographyStage" aria-live="polite">
  <p class="typography-stage__label" id="beatLabel">// presentation.init</p>
  <h1 class="typography-stage__primary" id="beatPrimary">LOADING</h1>
  <h2 class="typography-stage__secondary" id="beatSecondary"></h2>
  <div class="typography-stage__actions">
    <a class="typography-stage__cta btn btn-primary" id="beatCta" href="/cv" hidden>
      VER CV
    </a>
    <a class="typography-stage__cta btn btn-outline" id="beatContact" href={contactMailto} hidden>
      CONTACTAME
    </a>
  </div>
</div>

<!-- Burbujas de logros que entran al activarse cada beat -->
<div class="achievement-bubbles" id="achievementBubbles" aria-hidden="true"></div>

<div class="presentation-zones" aria-hidden="true">
  <button type="button" class="presentation-zone presentation-zone--prev" id="presentationZonePrev" tabindex="-1"></button>
  <button type="button" class="presentation-zone presentation-zone--next" id="presentationZoneNext" tabindex="-1"></button>
</div>

<div class="presentation-fallback" id="presentationFallback" hidden>
  <p>WebGL no disponible en este dispositivo.</p>
  <a href="/cv" class="btn btn-primary">VER CV</a>
</div>
