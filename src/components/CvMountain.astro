---
/*
  Montaña esquemática scroll-driven para el CV.
  Geometría low-poly generada en build-time: facetas triangulares con
  relleno slate tenue + aristas rojas (wireframe). El movimiento (zoom,
  paneo, fractura en rocas) lo controla /assets/js/cv-mountain.js.
*/
const W = 1200;
const H = 700;
const baseY = 580;

// Cresta principal (de izquierda a derecha). y menor = más alto.
const ridge = [
  { x: 40, y: 470 },
  { x: 210, y: 320 },
  { x: 360, y: 410 },
  { x: 520, y: 150 },
  { x: 660, y: 330 },
  { x: 820, y: 220 },
  { x: 980, y: 380 },
  { x: 1160, y: 480 },
];

const rows = 3;
const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

interface Facet {
  points: string;
  tint: number;
}

const facets: Facet[] = [];

for (let i = 0; i < ridge.length - 1; i += 1) {
  const left = ridge[i];
  const right = ridge[i + 1];

  for (let r = 0; r < rows; r += 1) {
    const t0 = r / rows;
    const t1 = (r + 1) / rows;

    const tlY = lerp(left.y, baseY, t0);
    const blY = lerp(left.y, baseY, t1);
    const trY = lerp(right.y, baseY, t0);
    const brY = lerp(right.y, baseY, t1);

    const TL = `${left.x},${tlY}`;
    const TR = `${right.x},${trY}`;
    const BR = `${right.x},${brY}`;
    const BL = `${left.x},${blY}`;

    // Alterna la diagonal para que la facetación no sea monótona.
    if ((i + r) % 2 === 0) {
      facets.push({ points: `${TL} ${TR} ${BR}`, tint: (i + r) % 3 });
      facets.push({ points: `${TL} ${BR} ${BL}`, tint: (i + r + 1) % 3 });
    } else {
      facets.push({ points: `${TL} ${TR} ${BL}`, tint: (i + r) % 3 });
      facets.push({ points: `${TR} ${BR} ${BL}`, tint: (i + r + 1) % 3 });
    }
  }
}

const ridgeLine = ridge.map((p) => `${p.x},${p.y}`).join(' ');
---

<div class="cv-mountain" aria-hidden="true" data-cv-mountain>
  <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="xMidYMid slice">
    <g class="cv-mountain__range" data-cv-range>
      {
        facets.map((f) => (
          <polygon class={`cv-mountain__facet cv-mountain__facet--t${f.tint}`} points={f.points} data-cv-facet />
        ))
      }
      <polyline class="cv-mountain__ridge" points={ridgeLine} />
    </g>
  </svg>
</div>
